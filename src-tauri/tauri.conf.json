{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "DnD Character Manager",
  "version": "0.1.0",
  "identifier": "ru.azzydreamer.dndmanager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:5173",
    "beforeDevCommand": "npm run dev -- --mode desktop",
    "beforeBuildCommand": "npm run build -- --mode desktop"
  },
  "app": {
    "windows": [
      {
        "title": "D&D Character Manager",
        "width": 1280,
        "height": 800,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": false,
        "shadow": true,
        "center": true,
        "theme": "Dark",
        "backgroundColor": "#0d0d12"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4OUE3N0MzMTRDNDUyQzgKUldUSVVzUVV3M2VhMkV3a0lpR0FsbGFxdlVGYllNQTV6aVJtc3J0eXBnalZnMjAyRTJSZjFaSHYK",
      "endpoints": [
        "https://upd.azzydreamer.ru/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis"],
    "windows": {
      "nsis": {
        "installMode": "currentUser"
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
