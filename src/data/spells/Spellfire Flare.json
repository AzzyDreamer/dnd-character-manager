	"entries": [
		"You unleash a blast of brilliant fire. Make a ranged spell attack against a target within range; a target gains no benefit from {@variantrule Cover|XPHB|Half Cover} or {@variantrule Cover|XPHB|Three-Quarters Cover} for this attack roll. On a hit, the target takes {@damage 2d10} Radiant damage."
	],
