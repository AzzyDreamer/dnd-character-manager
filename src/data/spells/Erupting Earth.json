		{
			"type": "entries",
			"name": "At Higher Levels",
			"entries": [
				"When you cast this spell using a spell slot of 4th level or higher, the damage increases by {@scaledamage 3d12|3-9|1d12} for each slot level above 3rd."
			]
		}
