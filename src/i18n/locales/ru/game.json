  "classes": {
    "artificer": { "name": "Изобретатель", "description": "Мастер магических изобретений, вплетающий заклинания в предметы. Создаёт устройства, оружие и броню с магическими свойствами." },
    "barbarian": { "name": "Варвар", "description": "Свирепый воин, черпающий силу из первобытной ярости. В бою входит в состояние неудержимого гнева." },
    "bard": { "name": "Бард", "description": "Вдохновляющий маг, чья сила проистекает из музыки и слов. Мастер на все руки." },
    "cleric": { "name": "Жрец", "description": "Божественный заклинатель, служащий высшей силе. Целитель и защитник веры." },
    "druid": { "name": "Друид", "description": "Хранитель природы, черпающий магию из первозданных сил мира. Может принимать облик зверей." },
    "fighter": { "name": "Воин", "description": "Мастер боевых искусств, владеющий любым оружием и доспехами. Непревзойдённый тактик." },
    "gunslinger": { "name": "Стрелок", "description": "Стрелок — мастер огнестрельного оружия, сочетающий молниеносную реакцию, точную стрельбу и дерзкие манёвры." },
    "monk": { "name": "Монах", "description": "Мастер боевых искусств, использующий внутреннюю энергию ки для невероятных подвигов." },
    "monster-hunter": { "name": "Охотник на монстров", "description": "Закалённый охотник, посвятивший жизнь уничтожению сверхъестественных угроз. Использует знания о монстрах и древние техники для выслеживания и уничтожения порождений тьмы." },
    "paladin": { "name": "Паладин", "description": "Святой воин, связанный священной клятвой. Сочетает божественную магию с боевым мастерством." },
    "ranger": { "name": "Следопыт", "description": "Воин дикой природы, мастер выживания и следопытства. Непревзойдённый охотник." },
    "rogue": { "name": "Плут", "description": "Ловкий специалист, полагающийся на хитрость и точные удары. Мастер скрытности и обмана." },
    "sorcerer": { "name": "Чародей", "description": "Врождённый маг, чья сила проистекает из крови или судьбы. Управляет сырой магической энергией." },
    "warlock": { "name": "Колдун", "description": "Маг, заключивший пакт с могущественной сущностью. Получает уникальные силы от своего покровителя." },
    "wizard": { "name": "Волшебник", "description": "Учёный маг, постигающий тайны мироздания через изучение заклинаний. Самый универсальный заклинатель." }
