  "classes": {
    "artificer": { "name": "Artificer", "description": "A master of magical inventions, weaving spells into objects. Creates devices, weapons, and armor with magical properties." },
    "barbarian": { "name": "Barbarian", "description": "A fierce warrior drawing strength from primal rage. Enters a state of unstoppable fury in battle." },
    "bard": { "name": "Bard", "description": "An inspiring mage whose power springs from music and words. A jack of all trades." },
    "cleric": { "name": "Cleric", "description": "A divine spellcaster serving a higher power. A healer and defender of faith." },
    "druid": { "name": "Druid", "description": "A guardian of nature, drawing magic from the primordial forces of the world. Can take the form of beasts." },
    "fighter": { "name": "Fighter", "description": "A master of martial combat, proficient with any weapon and armor. An unmatched tactician." },
    "gunslinger": { "name": "Gunslinger", "description": "A master of firearms, combining lightning reflexes, precise shooting, and daring maneuvers." },
    "monk": { "name": "Monk", "description": "A martial arts master who uses inner ki energy for incredible feats." },
    "monster-hunter": { "name": "Monster Hunter", "description": "A hardened hunter devoted to destroying supernatural threats. Uses monster knowledge and ancient techniques to track and eliminate creatures of darkness." },
    "paladin": { "name": "Paladin", "description": "A holy warrior bound by a sacred oath. Combines divine magic with martial prowess." },
    "ranger": { "name": "Ranger", "description": "A warrior of the wild, master of survival and tracking. An unmatched hunter." },
    "rogue": { "name": "Rogue", "description": "A nimble specialist relying on cunning and precise strikes. A master of stealth and deception." },
    "sorcerer": { "name": "Sorcerer", "description": "An innate mage whose power flows from blood or destiny. Controls raw magical energy." },
    "warlock": { "name": "Warlock", "description": "A mage who has made a pact with a powerful entity. Gains unique powers from their patron." },
    "wizard": { "name": "Wizard", "description": "A scholarly mage who uncovers the mysteries of the universe through the study of spells. The most versatile spellcaster." }
  },
